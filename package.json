{
  "name": "map-of-eng",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive semantic map of CMU Engineering publications",
  "engines": {
    "node": ">=22.8.0"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test --experimental-test-coverage --test-coverage-include='assets/colors.js' --test-coverage-include='assets/map-core.js' --test-coverage-branches=97 --test-coverage-lines=99 --test-coverage-functions=100 tests/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1"
  }
}
